# Database (use with docker-compose or external Postgres)
DATABASE_URL=postgresql+psycopg_async://clubapp:clubapp@localhost:5432/clubapp

# JWT secrets (generate random strings for production)
JWT_SECRET_STUDENT=change-me-student-jwt-secret
JWT_SECRET_ADMIN=change-me-admin-jwt-secret

# Admin bootstrap (password is hashed on first run if admins table empty — see README)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Google Sheets (optional — sync fails gracefully if unset)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# Spreadsheet ID from URL
GOOGLE_SHEETS_SPREADSHEET_ID=
# Sheet names / ranges (default: first row headers)
# 학생정보: 학번, 이름, …, 상태 — 상태가 재학/휴학 등이면 학적만 반영, 그 외는 동아리코드 또는 동아리명으로 선정 반영
GOOGLE_SHEETS_STUDENTS_RANGE=학생정보!A:F
GOOGLE_SHEETS_CLUBS_RANGE=동아리정보!A:F

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
